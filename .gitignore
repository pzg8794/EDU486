.DS_Store

# Keep third-party course files and local source artifacts local.
# The public repo documents these sources in docs/source-map.md instead.
_local-course-materials/

# Keep legacy locations protected if a download recreates them.
Module1/
Module2/
announcements/
camping/
Save this email for camp links/
assignments/receipt-*.txt
transcripts/*-transcript.txt
*.pdf
*.doc
*.docx
*.ppt
*.pptx
*.png
*.jpg
*.jpeg
*.gif
*.mp4
*.mov
*.zip

# Public generated artifacts that are safe to render on GitHub.
!public-artifacts/
!public-artifacts/*.md
!public-artifacts/*.png
!public-artifacts/*.svg

# Public submission exports generated from original course work.
!public-submissions/
!public-submissions/*.md
!public-submissions/*.docx
!public-submissions/*.pdf
!public-submissions/*.pptx
!public-submissions/*.png
!public-submissions/*.svg
!public-submissions/*.ics

# Course transcripts are publishable records when intentionally placed here.
!transcripts/raw/
!transcripts/raw/*.txt

# Local exports are for Blackboard/Drive submission, not the public repo.
submission_exports/
tmp/
